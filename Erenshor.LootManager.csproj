    <!-- ── ILRepack: merge ImGui.NET deps into output dll ─────────────────── -->
    <Target Name="ILRepack" AfterTargets="Build">
        <PropertyGroup>
            <ILRepackExe>$(SolutionDir)packages\ILRepack.2.0.18\tools\ILRepack.exe</ILRepackExe>
            <_OutDir>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\$(OutputPath)'))</_OutDir>
            <_OutDirNoSlash>$(_OutDir.TrimEnd('\'))</_OutDirNoSlash>
            <OutputAssembly>$(_OutDir)$(AssemblyName).dll</OutputAssembly>
        </PropertyGroup>
        <Exec Command="&quot;$(ILRepackExe)&quot; /ndebug /internalize /lib:&quot;$(_OutDirNoSlash)&quot; /out:&quot;$(OutputAssembly)&quot; &quot;$(OutputAssembly)&quot; &quot;$(_OutDir)ImGui.NET.dll&quot; &quot;$(_OutDir)System.Runtime.CompilerServices.Unsafe.dll&quot; &quot;$(_OutDir)System.Numerics.Vectors.dll&quot; &quot;$(_OutDir)System.Buffers.dll&quot;"
              ContinueOnError="true" />
    </Target>

